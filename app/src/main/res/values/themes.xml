<!-- res/values/themes.xml -->
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.TicketApp" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/Grayish_green</item>
        <item name="colorPrimaryVariant">@color/Grayish_lime</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- ... other items -->
    </style>

    <!-- ============================================= -->
    <!--          ESTILOS PARA BOTONES DE CANTIDAD     -->
    <!-- ============================================= -->

    <!-- Estilo para los botones de más y menos -->

    <!-- Estilo para el TextView que muestra la cantidad -->
    <style name="TextoCantidad">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minWidth">85dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

</resources>
