<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/BrigthSnow"
    tools:context="MainActivity">




    <!-- Main content: retains the existing ScrollView and order entry UI. -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        <LinearLayout
            android:id="@+id/rootLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:animateLayoutChanges="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginEnd="-1dp"
                android:layout_marginBottom="20dp"
                android:backgroundTint="@color/CarbonBlack"
                android:fontFamily="@font/akatab"
                android:text="Antojitos Mexicanos Margarita"
                android:textColor="@color/CarbonBlack"
                android:textSize="30sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/MaterialAlertDialog.MaterialComponents.Title.Icon"
                android:layout_width="369dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@color/Grayish_green"
                android:textColorHint="@color/Grayish_green">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editMesa"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/CharcoalCool"
                    android:hint="Mesa/Mesero(Opcional)"
                    android:imeOptions="actionDone"
                    android:inputType="textCapWords"
                    android:textColor="@color/text_secondary" />




            </com.google.android.material.textfield.TextInputLayout>
            <CheckBox
                android:id="@+id/noCuenta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/Text"
                android:checked="false"
                android:text="@string/incluir_n_mero_de_cuenta"
                android:textColor="@color/text_secondary"
                android:textSize="16dp" />
            <RelativeLayout android:id="@+id/headerPlatillos" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingTop="8dp" android:paddingBottom="8dp" android:background="?android:attr/selectableItemBackground" >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_marginStart="1dp"
                    android:fadingEdge="horizontal"
                    android:fontFamily="@font/akatab"
                    android:text="Platillos Principales"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:tint="@color/Grey" />

                <ImageView
                    android:id="@+id/arrowPlatillos"
                    android:layout_width="40dp"
                    android:layout_height="35dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="5dp"
                    android:src="@drawable/down_arrow"
                    android:rotation="0"
                    app:tint="@color/Grey"
                    />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider" />

            <ViewStub
                android:id="@+id/stubPlatillos"
                android:inflatedId="@+id/gridPlatillos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout="@layout/layout_grid_platillos" />

            <RelativeLayout
                android:id="@+id/headerEntradas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="?android:attr/selectableItemBackground"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/akatab"
                    android:text="Entradas"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/arrowEntradas"
                    android:layout_width="40dp"
                    android:layout_height="35dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="5dp"
                    android:src="@drawable/down_arrow"
                    app:tint="@color/Grey" />

            </RelativeLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?android:attr/listDivider"/>
            <ViewStub
                android:id="@+id/stubEntradas"
                android:inflatedId="@+id/gridEntradas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout="@layout/layout_grid_entradas" />
            <RelativeLayout android:id="@+id/headerPambazos" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:paddingTop="8dp" android:paddingBottom="8dp" android:background="?android:attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/akatab"
                    android:text="Pambazos"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/arrowPambazos"
                    android:layout_width="40dp"
                    android:layout_height="match_parent"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="5dp"
                    android:src="@drawable/down_arrow"
                    app:tint="@color/Grey" />
            </RelativeLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/florar_white"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"/>
            <ViewStub
                android:id="@+id/stubPambazos"
                android:inflatedId="@+id/gridPambazos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout="@layout/layout_grid_pambazos" />
            <RelativeLayout android:id="@+id/headerGuajoloyets" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:paddingTop="8dp" android:paddingBottom="8dp" android:background="?android:attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/akatab"
                    android:text="Guajoloyets"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <ImageView
                    android:id="@+id/arrowGuajoloyets"
                    android:layout_width="40dp"
                    android:layout_height="35dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="5dp"
                    android:src="@drawable/down_arrow"
                    app:tint="@color/Grey"
                    />
            </RelativeLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?android:attr/listDivider"/>
            <ViewStub
                android:id="@+id/stubGuajoloyets"
                android:inflatedId="@+id/gridGuajoloyets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout="@layout/layout_grid_guajoloyets" />


            <!-- ===================== HAMBURGUESAS ===================== -->
            <RelativeLayout
                android:id="@+id/headerHamburguesas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:background="?android:attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hamburguesas"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/akatab" />

                <ImageView
                    android:id="@+id/arrowHamburguesas"
                    android:layout_width="40dp"
                    android:layout_height="35dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="5dp"
                    android:src="@drawable/down_arrow"
                    app:tint="@color/Grey" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider" />

            <ViewStub
                android:id="@+id/stubHamburguesas"
                android:inflatedId="@+id/gridHamburguesas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout="@layout/layout_grid_hamburguesas" />


            <!-- ===================== PAPAS ===================== -->
            <RelativeLayout
                android:id="@+id/headerPapas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="?android:attr/selectableItemBackground"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/akatab"
                    android:text="Papas"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/arrowPapas"
                    android:layout_width="40dp"
                    android:layout_height="35dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="5dp"
                    android:src="@drawable/down_arrow"
                    app:tint="@color/Grey" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"/>

            <ViewStub
                android:id="@+id/stubPapas"
                android:inflatedId="@+id/gridPapas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout="@layout/layout_grid_papas" />
            <!-- ===================== TACOS ===================== -->
            <RelativeLayout
                android:id="@+id/headerTacos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="?android:attr/selectableItemBackground"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/akatab"
                    android:text="Tacos"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/arrowTacos"
                    android:layout_width="40dp"
                    android:layout_height="35dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="5dp"
                    android:src="@drawable/down_arrow"
                    app:tint="@color/Grey" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"/>

            <ViewStub
                android:id="@+id/stubTacos"
                android:inflatedId="@+id/gridTacos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout="@layout/layout_grid_tacos" />

            <!-- ===================== ALITAS ===================== -->
            <RelativeLayout
                android:id="@+id/headerAlitas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:background="?android:attr/selectableItemBackground">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/akatab"
                    android:text="Alitas"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
                <ImageView
                    android:id="@+id/arrowAlitas"
                    android:layout_width="40dp"
                    android:layout_height="35dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="5dp"
                    android:src="@drawable/down_arrow"
                    app:tint="@color/Grey"/>
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"/>

            <ViewStub
                android:id="@+id/stubAlitas"
                android:inflatedId="@+id/gridAlitas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout="@layout/layout_grid_alitas" />

            <RelativeLayout android:id="@+id/headerBebidas" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:paddingTop="8dp" android:paddingBottom="8dp" android:background="?android:attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/akatab"
                    android:text="Bebidas"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <ImageView
                    android:id="@+id/arrowBebidas"
                    android:layout_width="40dp"
                    android:layout_height="35dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="5dp"
                    android:src="@drawable/down_arrow"
                    app:tint="@color/Grey"
                    />
            </RelativeLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?android:attr/listDivider"/>
            <ViewStub
                android:id="@+id/stubBebidas"
                android:inflatedId="@+id/gridBebidas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout="@layout/layout_grid_bebidas" />
            <RelativeLayout android:id="@+id/headerPostres" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:paddingTop="8dp" android:paddingBottom="8dp" android:background="?android:attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_marginStart="0dp"
                    android:fontFamily="@font/akatab"
                    android:text="Postres y Extras"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/arrowPostres"
                    android:layout_width="40dp"
                    android:layout_height="35dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="5dp"
                    android:src="@drawable/down_arrow"
                    app:tint="@color/Grey"
                    />
            </RelativeLayout>
            <ViewStub
                android:id="@+id/stubPostres"
                android:inflatedId="@+id/gridPostres"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout="@layout/layout_grid_postres" />

            <LinearLayout
                android:id="@+id/summaryContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/Jet_Black"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone"
                tools:visibility="visible">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginTop="30dp"
                        android:fontFamily="@font/akatab"
                        android:text="Resumen de la Cuenta"
                        android:textAlignment="textStart"
                        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                        android:textColor="@color/text_primary"
                        android:textSize="47.78px"
                        android:textStyle="bold" />

                    <!-- Botón para cerrar el resumen -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCloseSummary"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="X"
                        android:textColor="@color/florar_white"
                        app:backgroundTint="@color/Grayish_green"
                        app:cornerRadius="20dp" />

                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="8dp"
                    android:background="@color/florar_white" />

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="200dp">

                    <TextView
                        android:id="@+id/summaryTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/akatab"
                        android:lineSpacingExtra="4dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="39.81px"
                        tools:text="2 x Quesadillas... $56.00\n1 x Pozole Grande... $110.00" />
                </ScrollView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="@color/florar_white" />

                <TextView
                    android:id="@+id/summaryTotalTextView"
                    android:layout_width="326dp"
                    android:layout_height="51dp"
                    android:drawableEnd="@drawable/payment"
                    android:drawableTint="@color/Grayish_green"
                    android:gravity="start|center_vertical"
                    android:paddingTop="8dp"
                    android:textAlignment="textStart"
                    android:textColor="@color/text_primary"
                    android:textSize="47.78px"
                    android:textStyle="bold"
                    tools:text="TOTAL: $166.00" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLimpiar"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:padding="16dp"
                    android:text="Limpiar Cantidades"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    app:strokeColor="@color/florar_white"/>

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnImprimir"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/akatab"
                android:padding="16dp"
                android:paddingBottom="25dp"
                android:text="Generar compra"
                android:textColor="@color/app_background"
                android:textSize="20dp"
                app:backgroundTint="@color/CarbonBlack"
                />

            <RadioGroup
                android:id="@+id/printerTypeGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/radioPrinter58"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Impresora 58mm (Bluetooth)"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />

                <RadioButton
                    android:id="@+id/radioPrinter80Network"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Impresora 80mm (Vía red)"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />

                <RadioButton
                    android:id="@+id/radioPrinter58Network"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Impresora 58mm (Vía red)"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />

                <LinearLayout
                    android:id="@+id/layoutPrinter80Help"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="32dp"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <ImageButton
                        android:id="@+id/btnPrinter80Help"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="Ayuda para impresora 80mm"
                        android:padding="4dp"
                        android:src="@drawable/help_24dp_e3e3e3_fill0_wght400_grad0_opsz24"
                        app:tint="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvPrinter80Help"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="Ayuda"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </LinearLayout>
            </RadioGroup>

            <com.google.android.material.button.MaterialButton android:id="@+id/btnEmparejar" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:padding="16dp" android:text="Emparejar Impresora Bluetooth" android:textColor="@color/text_primary" android:textSize="20sp" app:strokeColor="@color/florar_white"/>


            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="center_horizontal" android:layout_marginTop="20dp">


            </FrameLayout>
        </LinearLayout>
    </ScrollView>


    <!-- ===== Calculator Drawer (START) — swipe right to open ===== -->
    <include
        android:id="@+id/calculatorDrawer"
        layout="@layout/layout_calculator_drawer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

    <!-- Administración drawer that slides in from the right side. Contains
         summary actions, a list of orders and the totals display. -->

    <!-- ===== Admin Drawer with vertical scroll (END) ===== -->
    <!-- ===== Admin Drawer (END) con Scroll ===== -->

    <ScrollView
        android:id="@+id/adminDrawerScroll"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/app_background"
        android:scrollbars="vertical"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/adminDrawer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:fadingEdge="horizontal">

            <TextView
                android:id="@+id/adminTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Administración"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditarCatalogo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Editar precios y productos"
                android:textColor="@color/florar_white"
                app:backgroundTint="@color/old_grayish_green"
                app:cornerRadius="12dp" />

            <!-- Botones de ganancias -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGananciaDiaria"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Ganancia Diaria"
                android:textColor="@color/florar_white"
                app:backgroundTint="@color/Grayish_green"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGananciaSemanal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Ganancia Semanal"
                android:textColor="@color/florar_white"
                app:backgroundTint="@color/Grayish_green"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGananciaMensual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Ganancia Mensual"
                android:textColor="@color/florar_white"
                app:backgroundTint="@color/Grayish_green"
                app:cornerRadius="12dp" />

            <TextView
                android:id="@+id/adminSummaryTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <!-- Filtros -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProductSales"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:id="@+id/tvFilterTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Filtrar ventas por producto"
                        android:textColor="@color/text_secondary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerProductFilter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:spinnerMode="dropdown" />

                    <Spinner
                        android:id="@+id/spinnerPeriodFilter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:spinnerMode="dropdown" />

                    <Spinner
                        android:id="@+id/spinnerTypeFilter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:spinnerMode="dropdown" />

                    <LinearLayout
                        android:id="@+id/layoutCustomRange"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fecha inicio"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/editStartDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:clickable="true"
                            android:hint="Seleccione fecha de inicio"
                            android:padding="8dp"
                            android:background="@color/Light_grayish"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fecha fin"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/editEndDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:clickable="true"
                            android:hint="Seleccione fecha de fin"
                            android:padding="8dp"
                            android:background="@color/Light_grayish"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCalcularVentas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Calcular ventas"
                        android:textColor="@color/florar_white"
                        app:backgroundTint="@color/Grayish_green"
                        app:cornerRadius="12dp" />

                    <TextView
                        android:id="@+id/tvProductSalesResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:layout_marginBottom="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProfitByCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ganancia por categoría"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:textSize="16sp"
                        android:layout_marginBottom="8dp"/>

                    <!-- Categoría -->
                    <Spinner
                        android:id="@+id/spinnerCategoryProfit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:spinnerMode="dropdown" />

                    <!-- Periodo -->
                    <Spinner
                        android:id="@+id/spinnerCategoryPeriod"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:spinnerMode="dropdown" />

                    <!-- Rango personalizado (oculto inicialmente) -->
                    <LinearLayout
                        android:id="@+id/layoutCategoryCustomRange"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp">

                        <EditText
                            android:id="@+id/editCategoryStartDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:clickable="true"
                            android:inputType="none"
                            android:hint="Fecha inicio"
                            android:padding="8dp"
                            android:background="@color/Light_grayish"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:layout_marginBottom="8dp" />

                        <EditText
                            android:id="@+id/editCategoryEndDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:clickable="true"
                            android:inputType="none"
                            android:hint="Fecha fin"
                            android:padding="8dp"
                            android:background="@color/Light_grayish"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Incluir combos -->
                    <CheckBox
                        android:id="@+id/checkIncludeCombos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/night_grey"
                        android:text="Incluir combos"
                        android:checked="true"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCalcularGananciaCategoria"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Calcular ganancia"
                        android:textColor="@color/florar_white"
                        app:backgroundTint="@color/Grayish_green"
                        app:cornerRadius="12dp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvResultadoGananciaCategoria"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <!-- Lista de órdenes guardadas -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewOrders"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:nestedScrollingEnabled="true"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/textViewTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total: $0.00"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp" />

        </LinearLayout>
    </ScrollView>
    <!-- ===== /Admin Drawer ===== -->


</androidx.drawerlayout.widget.DrawerLayout>