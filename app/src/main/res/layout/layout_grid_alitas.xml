<?xml version="1.0" encoding="utf-8"?>
<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/gridAlitas"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:columnCount="3"
    android:useDefaultMargins="true">

    <!-- 6 pzas -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_columnWeight="1"
        app:cardBackgroundColor="@color/card_background"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="4dp">
            <TextView
                android:id="@+id/labelAlitas6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:gravity="center"
                android:minLines="2"
                android:text="Alitas 6 pzas"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMenosAlitas6"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="-"
                    android:textColor="@color/florar_white"
                    android:textSize="18sp"
                    app:backgroundTint="@color/Grayish_green"
                    app:cornerRadius="24dp"/>
                <TextView
                    android:id="@+id/cantidadAlitas6"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:minWidth="40dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:text="0"
                    android:textColor="@color/text_secondary"
                    android:textSize="18sp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMasAlitas6"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="+"
                    android:textColor="@color/florar_white"
                    android:textSize="18sp"
                    app:backgroundTint="@color/Grayish_green"
                    app:cornerRadius="24dp"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 10 pzas -->
