<?xml version="1.0" encoding="utf-8"?>
<!-- Fondo glass para encabezados de sección -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fondo translúcido -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="180"
                android:startColor="#66575A5E"
                android:endColor="#33222823"
                android:type="linear" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <!-- Borde glass superior brillante -->
    <item android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke
                android:width="1dp"
                android:color="#66F4F7F5" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</layer-list>
